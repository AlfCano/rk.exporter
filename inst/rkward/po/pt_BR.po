msgid "Batch Exporters"
msgstr "Exportadores em Lote (Batch)"

msgid "Batch Plot Exporter"
msgstr "Exportador de Gráficos em Lote"

msgid "Batch Table Exporter"
msgstr "Exportador de Tabelas em Lote"

msgid "Exporta una lista de gráficos (ggplot2) a archivos individuales o a un documento combinado (PDF, Word, PPTX)."
msgstr "Exporta uma lista de gráficos (ggplot2) para arquivos individuais ou um documento combinado (PDF, Word, PPTX)."

msgid "Exporta una lista de tablas (flextable) a archivos individuales o a un documento combinado (Word, PPTX)."
msgstr "Exporta uma lista de tabelas (flextable) para arquivos individuais ou um documento combinado (Word, PPTX)."

msgid "Target object (List of ggplot2 objects or single ggplot)"
msgstr "Objeto destino (Lista de objetos ggplot2 ou um único ggplot)"

