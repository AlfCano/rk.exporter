msgid "Batch Exporters"
msgstr "Exportadores por Lotes"

msgid "Batch Plot Exporter"
msgstr "Exportador de Gráficos por Lotes"

msgid "Batch Table Exporter"
msgstr "Exportador de Tablas por Lotes"

msgid "Exporta una lista de gráficos (ggplot2) a archivos individuales o a un documento combinado (PDF, Word, PPTX)."
msgstr "Exporta una lista de gráficos (ggplot2) a archivos individuales o a un documento combinado (PDF, Word, PPTX)."

msgid "Exporta una lista de tablas (flextable) a archivos individuales o a un documento combinado (Word, PPTX)."
msgstr "Exporta una lista de tablas (flextable) a archivos individuales o a un documento combinado (Word, PPTX)."

msgid "Target object (List of ggplot2 objects or single ggplot)"
msgstr "Objeto destino (Lista de objetos ggplot2 o un solo ggplot)"

