msgid "Batch Exporters"
msgstr "Stapel-Exportierer (Batch)"

msgid "Batch Plot Exporter"
msgstr "Stapel-Diagramm-Exportierer"

msgid "Batch Table Exporter"
msgstr "Stapel-Tabellen-Exportierer"

msgid "Exporta una lista de gráficos (ggplot2) a archivos individuales o a un documento combinado (PDF, Word, PPTX)."
msgstr "Exportiert eine Liste von Diagrammen (ggplot2) in einzelne Dateien oder ein kombiniertes Dokument (PDF, Word, PPTX)."

msgid "Exporta una lista de tablas (flextable) a archivos individuales o a un documento combinado (Word, PPTX)."
msgstr "Exportiert eine Liste von Tabellen (flextable) in einzelne Dateien oder ein kombiniertes Dokument (Word, PPTX)."

msgid "Target object (List of ggplot2 objects or single ggplot)"
msgstr "Zielobjekt (Liste von ggplot2-Objekten oder einzelnes ggplot)"

msgid "Target object (List of flextables or single flextable)"
msgstr "Zielobjekt (Liste von flextables oder einzelne flextable)"

msgid "Export Mode"
msgstr "Exportmodus"

msgid "Individual Files (e.g. plot_1.svg, plot_2.svg)"
msgstr "Einzelne Dateien (z.B. plot_1.svg, plot_2.svg)"

msgid "Combined Document (1 plot per page/slide)"
msgstr "Kombiniertes Dokument (1 Diagramm pro Seite/Folie)"

msgid "Individual Files (e.g. table_1.docx, table_2.docx)"
msgstr "Einzelne Dateien (z.B. table_1.docx, table_2.docx)"

msgid "Combined Document (1 table per page/slide)"
msgstr "Kombiniertes Dokument (1 Tabelle pro Seite/Folie)"

msgid "Output Directory (For Individual Files)"
msgstr "Ausgabeverzeichnis (Für Einzelne Dateien)"

msgid "Output File (For Combined Document, e.g. plots.pptx)"
msgstr "Ausgabedatei (Für Kombiniertes Dokument, z.B. plots.pptx)"

msgid "Output File (For Combined Document, e.g. tables.docx)"
msgstr "Ausgabedatei (Für Kombiniertes Dokument, z.B. tables.docx)"

msgid "Automatically append extension to file name if missing"
msgstr "Dateiendung automatisch anfügen, falls fehlend"

msgid "Format for Individual Files"
msgstr "Format für Einzelne Dateien"

msgid "Format for Combined Document"
msgstr "Format für Kombiniertes Dokument"

